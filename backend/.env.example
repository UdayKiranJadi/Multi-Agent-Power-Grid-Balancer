# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Required to run the balancer ---
OPENAI_API_KEY=sk-...            # national coordinator's LLM call
EIA_API_KEY=...                  # fetch_data.py / fetch_interchange.py (EIA API)

# --- Observability (optional but recommended) ---
LANGSMITH_API_KEY=...
LANGSMITH_TRACING=true

# --- API config ---
# Browser origins allowed to call the API. Comma-separated, or "*" for any.
# Leave unset for local dev; set to your real frontend URL in production.
# ALLOWED_ORIGINS=https://your-frontend.example.com
